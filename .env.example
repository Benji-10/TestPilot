# ============================================================
# TestPilot — Environment Variables
# ============================================================
# Copy this file to .env in the project root for local dev
# In Netlify: add these via Site Settings → Environment Variables
# ============================================================

# Neon.tech PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/testpilot?sslmode=require

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Netlify site URL (set automatically in production, needed for local dev)
# In dev: http://localhost:8888
URL=https://your-site.netlify.app

# Optional: Netlify Identity JWT secret (for local dev token verification)
# Get from Netlify dashboard → Site Settings → Identity → JWT secret
# NETLIFY_IDENTITY_SECRET=your-secret
