# ============================================================
# TestPilot — Environment Variables
# ============================================================
# Add ALL of these in Netlify: Site Settings → Environment Variables
# ============================================================

# Neon.tech PostgreSQL connection string
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/testpilot?sslmode=require

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# Netlify Identity JWT Secret  ← THIS IS THE IMPORTANT ONE
# Get from: Netlify Dashboard → Site Settings → Identity → scroll down to "JWT secret" → reveal
# Without this, auth falls back to trusting tokens unverified (works but insecure)
NETLIFY_IDENTITY_JWT_SECRET=your-jwt-secret-here

# Your Netlify site URL (set automatically by Netlify in production)
URL=https://your-site.netlify.app
